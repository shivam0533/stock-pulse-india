VITE_API_BASE_URL=https://api.stockpulse.in/v1
VITE_WS_URL=wss://stream.stockpulse.in
VITE_APP_NAME=Stock Pulse India
VITE_ENABLE_MOCK_API=true

# Real backend (Angel One broker integration, backend/) — set this to your
# deployed backend's URL (e.g. Railway/Render). Used by
# src/api/brokerApiClient.ts and the option-chain SSE stream. Leave unset for
# local development (falls back to the Vite dev-server proxy at /api).
VITE_API_URL=

# Developer-only — disables the 3:20 PM IST auto square-off so Active Trade
# ticking can be observed outside market hours. Has no effect in a
# production build regardless of this value (see src/config/devTestingMode.ts).
# Leave false/unset unless you are actively testing.
VITE_DEV_TESTING_MODE=false
