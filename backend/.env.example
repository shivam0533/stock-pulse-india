# Broker integration backend — copy this file to .env (already gitignored)
# and fill in real values. Never commit real credentials.

PORT=4000

# Kotak Neo (Kotak Securities Trade API)
KOTAK_CONSUMER_KEY=
KOTAK_CONSUMER_SECRET=
KOTAK_BASE_URL=

# Angel One SmartAPI (from smartapi.angelone.in -> My Apps -> API Key)
ANGEL_ONE_API_KEY=

# This app's own account system (backend/auth/*) + Admin Panel (backend/admin/*)
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
# Comma-separated emails that get role='admin' the moment they sign up or
# log in for real — e.g. ADMIN_EMAILS=you@example.com,teammate@example.com
ADMIN_EMAILS=
